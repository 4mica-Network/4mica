{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "4Mica",
  "description": "The clearinghouse for the agentic economy",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Integration",
        "pages": [
          "installation",
          "registration",
          "server-integration",
          "client-integration",
          "verified-payments"
        ]
      },
      {
        "group": "API Reference",
        "pages": ["facilitator-api", "operator-api", "payment-flow"]
      },
      {
        "group": "Examples",
        "pages": ["code-examples"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://4mica.io",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/4Mica-Network",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@4mica.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.4mica.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/0x4Mica",
      "github": "https://github.com/4Mica-Network",
      "linkedin": "https://linkedin.com/company/4mica"
    }
  }
}
