{
  "name": "4mica",
  "private": true,
  "imports": {
    "#*": "./src/*"
  },
  "keywords": [],
  "type": "module",
  "exports": null,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/4mica-Network/homepage.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "biome check .",
    "test": "turbo run test",
    "lint:write": "biome check --write --diagnostic-level=error .",
    "lint:linter": "biome lint --write --diagnostic-level=error .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@4mica/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/npm-registry-fetch": "^8.0.9",
    "@vitest/coverage-v8": "^4.1.8",
    "changelogen": "^0.6.2",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "ky": "^2.0.2",
    "lint-staged": "^17.0.7",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "rimraf": "^6.1.3",
    "taze": "^19.14.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "latest",
    "typescript": "latest",
    "vitest": "^4.1.8",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": "^14.18.0 || >=16.10.0"
  },
  "pkg": {
    "outputPath": "./package/"
  },
  "packageManager": "pnpm@10.28.2",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@biomejs/cli-darwin-x64": "^2.4.16",
    "execa": "^9.6.1",
    "find-up": "^8.0.0",
    "npm-registry-fetch": "^20.0.0",
    "read-pkg": "^10.1.0",
    "terminal-link": "^5.0.0"
  }
